# ── Supabase (required) ────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Nvidia (required for playbook) ──────────────────────
NVIDIA_API_KEY=nvapi-...

# ── Redis (optional — used for rate limiting future) ───────
REDIS_URL=redis://localhost:6379

# ── Google Search (optional — public scrape works without) ─
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ── Reddit (optional — public JSON API works without) ──────
# Get from: https://www.reddit.com/prefs/apps → create app → script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── HuggingFace (optional — only if hitting download limits) 
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=

# ── Demo config ────────────────────────────────────────────
APP_ENV=development
DEMO_MODE=true

# ── Competitor panel (optional — pre-wire brand UUIDs) ─────
# Comma-separated UUIDs of brands to show in competitor panel
COMPETITOR_BRAND_IDS=
